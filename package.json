{
  "name": "businessos-core",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "businessos-core — deterministic event-sourced kernel with pluggable business modules. Backend for a separately-built UI.",
  "scripts": {
    "test": "pnpm -r --workspace-concurrency=1 test",
    "typecheck": "pnpm -r typecheck",
    "migrate": "pnpm --filter @businessos/kernel migrate",
    "demo": "pnpm --filter @businessos/kernel demo",
    "dev:api": "pnpm --filter @businessos/api dev",
    "migrate:test": "DATABASE_URL=$DATABASE_URL_TEST pnpm --filter @businessos/kernel migrate"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
